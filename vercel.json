{
  "version": 2,
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "installCommand": "npm install --legacy-peer-deps && npm install ajv ajv-keywords --legacy-peer-deps",
      "buildCommand": "npm run build"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/_/backend",
      "installCommand": "pip install -r requirements.txt"
    }
  }
}
